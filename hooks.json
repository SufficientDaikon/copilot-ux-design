{
  "hooks": {
    "SessionStart": [
      {
        "type": "command",
        "command": "./scripts/detect-wireframes-ia.sh",
        "windows": "powershell -ExecutionPolicy Bypass -File scripts\\detect-wireframes-ia.ps1",
        "timeout": 10
      }
    ],
    "Stop": [
      {
        "type": "command",
        "command": "./scripts/on-ux-spec-complete.sh",
        "windows": "powershell -ExecutionPolicy Bypass -File scripts\\on-ux-spec-complete.ps1",
        "timeout": 10
      }
    ]
  }
}
